# Copy to .env and fill in your API keys
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_TTS_API_KEY=your_google_tts_api_key_here
# Local Ollama LLM for AI test / predictive / paper generation (ollama serve + `ollama pull llama3`).
# Called via the Vite dev proxy "/ollama". Leave VITE_OLLAMA_URL unset to use the proxy default (http://localhost:11434).
VITE_OLLAMA_MODEL=llama3
VITE_OLLAMA_TIMEOUT_MS=3000000
# Local n8n webhooks (production URLs — workflow must be Active). See n8n/README.md
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/bap-lead
VITE_N8N_REGISTER_URL=http://localhost:5678/webhook/bap-register
VITE_N8N_BROADCAST_URL=http://localhost:5678/webhook/bap-broadcast
