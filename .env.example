# Copy to .env and fill in your API keys
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_TTS_API_KEY=your_google_tts_api_key_here
# Local n8n webhooks (production URLs — workflow must be Active). See n8n/README.md
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/estudy-lead
VITE_N8N_REGISTER_URL=http://localhost:5678/webhook/estudy-register
VITE_N8N_BROADCAST_URL=http://localhost:5678/webhook/estudy-broadcast
