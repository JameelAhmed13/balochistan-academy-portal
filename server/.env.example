# Copy to server/.env
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d
DB_PATH=./data/estudy.db
# Initial admin seeded by `npm run db:seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Where the Python ingester writes its JSON (consumed by seed.js)
INGEST_DIR=../scripts/ingest/out
