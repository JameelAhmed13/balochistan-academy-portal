<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for Balochistan Academy Portal (Vue 3 SPA)
  Port: 7002 (configured in IIS Manager — not here)

  Prerequisites in IIS:
    1. URL Rewrite module  (iis.net/downloads/microsoft/url-rewrite)
    2. Application Request Routing (ARR) 3.0  (iis.net/downloads/microsoft/application-request-routing)
       → After install: IIS Manager → Server level → Application Request Routing → Server Proxy Settings → Enable proxy
    3. WebSocket Protocol feature  (Windows Features → IIS → WebSocket Protocol)

  .NET backend must be running on http://localhost:7014 (Kestrel / Windows Service).
  To change the backend URL, update the rewrite targets in the API and SignalR rules below.
-->
<configuration>
  <system.webServer>

    <!-- Enable WebSocket protocol for SignalR real-time notifications -->
    <webSocket enabled="true" />

    <!-- Serve index.html when the root is requested -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- MIME types for modern web assets -->
    <staticContent>
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js"   mimeType="application/javascript" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs"  mimeType="application/javascript" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg"  mimeType="image/svg+xml" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff"  mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <rewrite>
      <rules>

        <!-- ① Reverse-proxy: /api/* → .NET Kestrel backend -->
        <rule name="API Reverse Proxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^(.+)://" />
          </conditions>
          <action type="Rewrite" url="http://localhost:7014/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="{C:1}" />
          </serverVariables>
        </rule>

        <!-- ② Reverse-proxy: /hubs/* → SignalR WebSocket hub -->
        <rule name="SignalR Reverse Proxy" stopProcessing="true">
          <match url="^hubs/(.*)" />
          <action type="Rewrite" url="http://localhost:7014/hubs/{R:1}" />
        </rule>

        <!-- ③ Swagger docs proxy (optional — remove if not exposing in production) -->
        <rule name="Swagger Proxy" stopProcessing="true">
          <match url="^docs(.*)" />
          <action type="Rewrite" url="http://localhost:7014/docs{R:1}" />
        </rule>

        <!-- ④ SPA fallback — serve index.html for all non-file, non-directory routes -->
        <rule name="SPA History Mode Fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- Cache hashed static assets for 1 year; no-cache for index.html -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Long-term cache for Vite's content-hashed assets -->
    <outboundRules>
      <rule name="Cache hashed assets">
        <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
        <conditions>
          <!-- Vite asset files have a hash in the filename -->
          <add input="{REQUEST_URI}" pattern="^/assets/" />
        </conditions>
        <action type="Rewrite" value="public, max-age=31536000, immutable" />
      </rule>
      <rule name="No-cache index.html">
        <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
        <conditions>
          <add input="{REQUEST_URI}" pattern="^/index\.html$" />
        </conditions>
        <action type="Rewrite" value="no-store, no-cache, must-revalidate" />
      </rule>
    </outboundRules>

    <!-- Suppress IIS detailed errors; let the SPA handle them -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
